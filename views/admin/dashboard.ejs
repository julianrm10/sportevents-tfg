<% const title = 'Panel de administración' %>
<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<%
const SPORT_ICON   = { futbol:'⚽', baloncesto:'🏀', tenis:'🎾' };
const SPORT_LABEL  = { futbol:'Fútbol', baloncesto:'Baloncesto', tenis:'Tenis' };
const ESTADO_COLOR = { abierto:'success', en_curso:'warning', finalizado:'secondary' };
const ESTADO_LABEL = { abierto:'Abierto', en_curso:'En curso', finalizado:'Finalizado' };
%>

<main class="flex-grow-1">
  <div class="container py-4">

    <!-- Cabecera -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
      <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard</h2>
        <p class="text-muted mb-0">Panel de control de SportEvents</p>
      </div>
      <a href="/eventos/crear" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Crear evento
      </a>
    </div>

    <!-- Estadísticas -->
    <div class="row g-3 mb-4">
      <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
              <i class="bi bi-calendar3"></i>
            </div>
            <div>
              <div class="h3 fw-bold mb-0"><%= stats.totalEvents %></div>
              <div class="text-muted small">Eventos creados</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
              <i class="bi bi-shield"></i>
            </div>
            <div>
              <div class="h3 fw-bold mb-0"><%= stats.totalTeams %></div>
              <div class="text-muted small">Equipos creados</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
              <i class="bi bi-person-check"></i>
            </div>
            <div>
              <div class="h3 fw-bold mb-0"><%= stats.inscribedTeams %></div>
              <div class="text-muted small">Equipos inscritos</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="stat-icon bg-info bg-opacity-10 text-info">
              <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
              <div class="h3 fw-bold mb-0"><%= stats.pendingMatches %></div>
              <div class="text-muted small">Partidos pendientes</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Accesos rápidos -->
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <a href="/admin/eventos" class="card border-0 shadow-sm text-decoration-none text-dark h-100 admin-link-card">
          <div class="card-body text-center py-4">
            <i class="bi bi-calendar3 fs-1 text-primary mb-2 d-block"></i>
            <h6 class="fw-bold mb-1">Gestionar Eventos</h6>
            <small class="text-muted">Ver, editar y eliminar eventos</small>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/admin/partidos" class="card border-0 shadow-sm text-decoration-none text-dark h-100 admin-link-card">
          <div class="card-body text-center py-4">
            <i class="bi bi-controller fs-1 text-success mb-2 d-block"></i>
            <h6 class="fw-bold mb-1">Gestionar Partidos</h6>
            <small class="text-muted">Crear y actualizar resultados</small>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/eventos/crear" class="card border-0 shadow-sm text-decoration-none text-dark h-100 admin-link-card">
          <div class="card-body text-center py-4">
            <i class="bi bi-plus-circle fs-1 text-warning mb-2 d-block"></i>
            <h6 class="fw-bold mb-1">Crear Evento</h6>
            <small class="text-muted">Añadir un nuevo evento</small>
          </div>
        </a>
      </div>
    </div>

    <!-- Últimos eventos -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom fw-bold py-3">
        <i class="bi bi-clock-history text-primary me-2"></i>Últimos eventos
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Evento</th>
              <th>Tipo</th>
              <th>Fecha</th>
              <th>Estado</th>
              <th>Inscritos</th>
              <th class="text-center">Pendientes</th>
              <th class="text-center">Jugados</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (!recentEvents.length) { %>
            <tr><td colspan="8" class="text-center py-3 text-muted">No hay eventos aún</td></tr>
            <% } %>
            <% recentEvents.forEach(ev => { %>
            <tr>
              <td class="fw-semibold"><%= ev.titulo %></td>
              <td><%= SPORT_ICON[ev.tipo] %> <%= SPORT_LABEL[ev.tipo] %></td>
              <td class="small"><%= new Date(ev.fecha).toLocaleDateString('es-ES') %></td>
              <td>
                <span class="badge bg-<%= ESTADO_COLOR[ev.estado] %>">
                  <%= ESTADO_LABEL[ev.estado] %>
                </span>
              </td>
              <td><%= ev.reg_count %> / <%= ev.max_equipos %></td>
              <td class="text-center">
                <% if (ev.pending_matches > 0) { %>
                <span class="badge bg-warning text-dark"><%= ev.pending_matches %></span>
                <% } else { %>
                <span class="text-muted small">—</span>
                <% } %>
              </td>
              <td class="text-center">
                <% if (ev.played_matches > 0) { %>
                <span class="badge bg-success"><%= ev.played_matches %></span>
                <% } else { %>
                <span class="text-muted small">—</span>
                <% } %>
              </td>
              <td>
                <a href="/eventos/<%= ev.id %>" class="btn btn-sm btn-outline-primary">Ver</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-white border-top text-end py-2">
        <a href="/admin/eventos" class="btn btn-sm btn-link">Ver todos los eventos →</a>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
