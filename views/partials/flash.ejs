<% if (flash.success && flash.success.length) { %>
  <% flash.success.forEach(msg => { %>
  <div class="alert alert-success alert-dismissible fade show flash-alert mb-0 rounded-0 border-0 border-bottom" role="alert">
    <div class="container d-flex align-items-center gap-2">
      <i class="bi bi-check-circle-fill flex-shrink-0"></i>
      <span><%= msg %></span>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
  </div>
  <% }) %>
<% } %>
<% if (flash.error && flash.error.length) { %>
  <% flash.error.forEach(msg => { %>
  <div class="alert alert-danger alert-dismissible fade show flash-alert mb-0 rounded-0 border-0 border-bottom" role="alert">
    <div class="container d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
      <span><%= msg %></span>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
  </div>
  <% }) %>
<% } %>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    setTimeout(function () {
      document.querySelectorAll('.flash-alert').forEach(function (el) {
        el.classList.remove('show');
        setTimeout(function () { el.remove(); }, 300);
      });
    }, 3000);
  });
</script>
