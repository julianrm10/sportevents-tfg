<% const title = 'Eventos deportivos' %>
<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<%
const SPORT_ICON  = { futbol:'⚽', baloncesto:'🏀', tenis:'🎾' };
const SPORT_COLOR = { futbol:'success', baloncesto:'warning', tenis:'info' };
const SPORT_LABEL = { futbol:'Fútbol', baloncesto:'Baloncesto', tenis:'Tenis' };
const ESTADO_COLOR= { abierto:'success', en_curso:'warning', finalizado:'secondary' };
const ESTADO_LABEL= { abierto:'Abierto', en_curso:'En curso', finalizado:'Finalizado' };
%>

<!-- Hero -->
<div class="container-lg px-3 px-lg-4 mt-3 mb-4">
  <section class="event-detail-hero position-relative rounded-4 overflow-hidden">
    <img src="https://img.magnific.com/foto-gratis/vector-campo-futbol-americano_23-2151117450.jpg"
         class="event-hero-img" alt="Eventos Deportivos">
    <div class="event-hero-overlay"></div>
    <div class="position-absolute top-0 start-0 end-0 bottom-0 d-flex align-items-center justify-content-center text-center text-white px-4"
         style="z-index:1">
      <div>
        <h1 class="display-4 fw-bold mb-3" style="text-shadow:0 2px 8px rgba(0,0,0,.5)">
          Eventos Deportivos
        </h1>
        <p class="lead mb-4" style="opacity:.85">
          Encuentra, inscríbete y compite en los mejores torneos de tu zona.
        </p>
        <% if (user && user.role === 'admin') { %>
        <a href="/eventos/crear" class="btn btn-light btn-lg fw-semibold text-dark">
          <i class="bi bi-plus-circle me-2"></i>Crear evento
        </a>
        <% } else if (!user) { %>
        <a href="/auth/register" class="btn btn-light btn-lg fw-semibold text-dark">
          <i class="bi bi-trophy me-2"></i>Regístrate para competir
        </a>
        <% } %>
      </div>
    </div>
  </section>
</div>

<main class="flex-grow-1">
  <div class="container py-4">

    <!-- Filtros -->
    <div class="d-flex flex-wrap align-items-center gap-4 mb-4">

      <!-- Grupo: Deporte -->
      <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="fw-semibold text-muted">Deporte:</span>
        <a href="/eventos<%= estado ? '?estado='+estado : '' %>"
           class="btn btn-sm <%= !tipo ? 'btn-primary' : 'btn-outline-primary' %>">
          Todos
        </a>
        <a href="/eventos?tipo=futbol<%= estado ? '&estado='+estado : '' %>"
           class="btn btn-sm <%= tipo==='futbol' ? 'btn-success'           : 'btn-outline-success' %>">
          ⚽ Fútbol
        </a>
        <a href="/eventos?tipo=baloncesto<%= estado ? '&estado='+estado : '' %>"
           class="btn btn-sm <%= tipo==='baloncesto'  ? 'btn-warning text-dark' : 'btn-outline-warning' %>">
          🏀 Baloncesto
        </a>
        <a href="/eventos?tipo=tenis<%= estado ? '&estado='+estado : '' %>"
           class="btn btn-sm <%= tipo==='tenis'       ? 'btn-info text-dark'    : 'btn-outline-info' %>">
          🎾 Tenis
        </a>
      </div>

      <div class="vr d-none d-md-block"></div>

      <!-- Grupo: Estado -->
      <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="fw-semibold text-muted">Estado:</span>
        <a href="/eventos<%= tipo ? '?tipo='+tipo : '' %>"
           class="btn btn-sm <%= !estado ? 'btn-dark' : 'btn-outline-dark' %>">
          Todos
        </a>
        <a href="/eventos?estado=abierto<%= tipo ? '&tipo='+tipo : '' %>"
           class="btn btn-sm <%= estado==='abierto'    ? 'btn-success'           : 'btn-outline-success' %>">
          Abierto
        </a>
        <a href="/eventos?estado=en_curso<%= tipo ? '&tipo='+tipo : '' %>"
           class="btn btn-sm <%= estado==='en_curso'   ? 'btn-warning text-dark' : 'btn-outline-warning' %>">
          En curso
        </a>
        <a href="/eventos?estado=finalizado<%= tipo ? '&tipo='+tipo : '' %>"
           class="btn btn-sm <%= estado==='finalizado' ? 'btn-secondary'         : 'btn-outline-secondary' %>">
          Finalizado
        </a>
      </div>

    </div>

    <!-- Tarjetas de eventos -->
    <% if (!events.length) { %>
    <div class="text-center py-5">
      <div class="display-1 text-muted">🏟️</div>
      <h3 class="text-muted mt-3">No hay eventos disponibles</h3>
      <p class="text-muted">
        <% if (tipo || estado) { %>
          No encontramos eventos
          <% if (tipo) { %> de tipo <strong><%= tipo %></strong><% } %>
          <% if (tipo && estado) { %> con estado<% } else if (estado) { %> con estado<% } %>
          <% if (estado) { %> <strong><%= estado.replace('_',' ') %></strong><% } %>.
          <a href="/eventos">Ver todos los eventos</a>
        <% } else { %>
          Todavía no se han creado eventos. ¡Vuelve pronto!
        <% } %>
      </p>
    </div>
    <% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% events.forEach(ev => { %>
      <div class="col">
        <div class="card h-100 event-card shadow-sm border-0">

          <!-- Imagen o placeholder -->
          <% if (ev.imagen) { %>
          <img src="/uploads/<%= ev.imagen %>" class="card-img-top event-thumb" alt="<%= ev.titulo %>">
          <% } else { %>
          <div class="event-placeholder sport-bg-<%= ev.tipo %> d-flex align-items-center justify-content-center">
            <span class="sport-emoji"><%= SPORT_ICON[ev.tipo] %></span>
          </div>
          <% } %>

          <div class="card-body d-flex flex-column">
            <!-- Badges -->
            <div class="d-flex gap-2 mb-2 flex-wrap">
              <span class="badge bg-<%= SPORT_COLOR[ev.tipo] %> text-<%= ev.tipo==='baloncesto'||ev.tipo==='tenis' ? 'dark' : 'white' %>">
                <%= SPORT_ICON[ev.tipo] %> <%= SPORT_LABEL[ev.tipo] %>
              </span>
              <span class="badge bg-<%= ESTADO_COLOR[ev.estado] %>">
                <%= ESTADO_LABEL[ev.estado] %>
              </span>
            </div>

            <h5 class="card-title fw-bold mb-1"><%= ev.titulo %></h5>

            <% if (ev.descripcion) { %>
            <p class="card-text text-muted small mb-2 text-truncate-2"><%= ev.descripcion %></p>
            <% } %>

            <div class="mt-auto">
              <ul class="list-unstyled small text-muted mb-3">
                <li class="mb-1"><i class="bi bi-calendar3 me-1 text-primary"></i>
                  <%= new Date(ev.fecha).toLocaleString('es-ES', {day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}) %>
                </li>
                <li class="mb-1"><i class="bi bi-geo-alt me-1 text-primary"></i><%= ev.lugar %></li>
                <li>
                  <i class="bi bi-people me-1 text-primary"></i>
                  <span class="<%= ev.reg_count >= ev.max_equipos ? 'text-danger fw-semibold' : '' %>">
                    <%= ev.reg_count %> / <%= ev.max_equipos %>
                  </span>
                  equipos
                </li>
              </ul>
              <a href="/eventos/<%= ev.id %>" class="btn btn-primary btn-sm w-100">
                Ver evento <i class="bi bi-arrow-right ms-1"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
