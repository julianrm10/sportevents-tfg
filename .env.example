# Puerto en el que escucha el servidor
PORT=3000

# Host de la base de datos MySQL
DB_HOST=localhost

# Usuario de la base de datos
DB_USER=root

# Contraseña de la base de datos (dejar vacío si no tiene)
DB_PASSWORD=

# Nombre de la base de datos
DB_NAME=eventosport

# Clave secreta para las sesiones de usuario (cámbiala en producción)
SESSION_SECRET=cambia_esta_clave_en_produccion

# Clave de la API de GNews para obtener noticias deportivas
# Obtén una gratuita en https://gnews.io
NEWS_API_KEY=tu_api_key_de_gnews
